# Reference defaults for catalog maintainers. Connect generates secrets/.env.local
# with selected keys and preserves existing non-empty values; do not copy this whole file.
# Do not commit secrets/.env.local.

# Google OAuth onboarding.
# Prefer credentials authorized for the intended account. For organizational accounts,
# use the organization's approved vault or onboarding pack when one is provided.
# Browser login creates user tokens for the signed-in account.
# Any key can also be supplied through KEY_FILE. When KEY is empty and KEY_FILE points
# to an existing ignored local file, the helper reads the value from that file.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CLIENT_ID_FILE=
GOOGLE_CLIENT_SECRET_FILE=
GOOGLE_OAUTH_CLIENT_JSON=%USERPROFILE%\.web-analyst-agent\google-oauth-client.json

# Google Drive local onboarding MCP.
GDRIVE_OAUTH_PATH=%USERPROFILE%\.web-analyst-agent\google-oauth-client.json
GDRIVE_CREDENTIALS_PATH=%USERPROFILE%\.web-analyst-agent\gdrive-credentials.json

# Gmail local onboarding MCP.
GMAIL_OAUTH_PATH=%USERPROFILE%\.web-analyst-agent\google-oauth-client.json
GMAIL_CREDENTIALS_PATH=%USERPROFILE%\.web-analyst-agent\gmail-credentials.json

# Google Analytics official ADC.
# GOOGLE_ADC_CLIENT_JSON usually points to GOOGLE_OAUTH_CLIENT_JSON.
# GOOGLE_APPLICATION_CREDENTIALS is the ADC file path printed by gcloud after login.
GOOGLE_PROJECT_ID=
GOOGLE_ADC_CLIENT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=

# BigQuery official remote MCP / MCP Toolbox fallback.
# Keep this empty until the account owner or applicable organization confirms the project and datasets.
# BIGQUERY_MCP_ACCESS_TOKEN is a short-lived local bridge generated by BigQueryAdcBearerToken
# when remote OAuth is blocked. It should not be pasted manually unless explicitly approved.
BIGQUERY_PROJECT_ID=
BIGQUERY_DATASETS=
BIGQUERY_REGION=
BIGQUERY_MAX_BYTES_BILLED=
BIGQUERY_MCP_ACCESS_TOKEN=

# Google Tag Manager via Stape remote OAuth does not need local secrets by default.
# Keep advanced/headless credentials outside this template unless explicitly chosen.

# ClickUp official remote MCP uses browser OAuth by default.

# Trello candidate MCP.
TRELLO_API_KEY=
TRELLO_TOKEN=
TRELLO_API_KEY_FILE=
TRELLO_TOKEN_FILE=

# Piano Analytics official MCP private beta.
PIANO_ACCESS_KEY=
PIANO_SECRET_KEY=
PIANO_ACCESS_KEY_FILE=
PIANO_SECRET_KEY_FILE=

# Piano Analytics API connector fallback.
PIANO_SITE_ID=
PIANO_API_BASE_URL=https://api.atinternet.io

# Tag Commander / Commanders Act API connector.
TAG_COMMANDER_API_KEY=
TAG_COMMANDER_SITE_ID=
TAG_COMMANDER_API_BASE_URL=
TAG_COMMANDER_API_KEY_FILE=

# Contentsquare official MCP.
# Copy the exact MCP URL from Contentsquare > Analysis setup > Model Context Protocol.
CONTENTSQUARE_MCP_URL=
